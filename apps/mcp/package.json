{
  "name": "@llm-water-tracker/mcp",
  "type": "module",
  "version": "18.0.10",
  "description": "MCP server implementation for llm-water-tracker data",
  "author": "Udit Garg",
  "license": "MIT",
  "funding": "https://github.com/procrastinate-coders/llm-water-tracker?sponsor=1",
  "homepage": "https://github.com/procrastinate-coders/llm-water-tracker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procrastinate-coders/llm-water-tracker.git",
    "directory": "apps/mcp"
  },
  "bugs": {
    "url": "https://github.com/procrastinate-coders/llm-water-tracker/issues"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "llm-water-mcp": "./src/index.ts"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "bin": {
      "llm-water-mcp": "./dist/index.js"
    },
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "dependencies": {
    "@hono/mcp": "catalog:runtime",
    "@hono/node-server": "catalog:runtime",
    "@modelcontextprotocol/sdk": "catalog:runtime",
    "llm-water-codex": "workspace:*",
    "llm-water-tracker": "workspace:*",
    "gunshi": "catalog:runtime",
    "hono": "catalog:runtime",
    "nano-spawn": "catalog:runtime",
    "zod": "catalog:runtime"
  }
}
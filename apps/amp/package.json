{
	"name": "llm-water-amp",
	"type": "module",
	"version": "18.0.12",
	"description": "Track Amp AI agent token usage, costs, and water consumption. Daily, monthly, and session reports with water footprint data.",
	"author": "Udit Garg",
	"license": "MIT",
	"funding": "https://github.com/procrastinate-coders/llm-water-tracker?sponsor=1",
	"homepage": "https://github.com/procrastinate-coders/llm-water-tracker#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/procrastinate-coders/llm-water-tracker.git",
		"directory": "apps/amp"
	},
	"bugs": {
		"url": "https://github.com/procrastinate-coders/llm-water-tracker/issues"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"bin": {
		"llm-water-amp": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"bin": {
			"llm-water-amp": "./dist/index.js"
		}
	},
	"engines": {
		"node": ">=20.19.4"
	},
	"scripts": {
		"build": "tsdown",
		"format": "pnpm run lint --fix",
		"lint": "eslint --cache .",
		"prepack": "pnpm run build && clean-pkg-json",
		"prerelease": "pnpm run lint && pnpm run typecheck && pnpm run build",
		"start": "bun ./src/index.ts",
		"test": "TZ=UTC vitest",
		"typecheck": "tsgo --noEmit"
	},
	"devDependencies": {
		"@llm-water-tracker/internal": "workspace:*",
		"@llm-water-tracker/terminal": "workspace:*",
		"@praha/byethrow": "catalog:runtime",
		"@typescript/native-preview": "catalog:types",
		"clean-pkg-json": "catalog:release",
		"eslint": "catalog:lint",
		"fast-sort": "catalog:runtime",
		"typescript-eslint": "catalog:lint",
		"fs-fixture": "catalog:testing",
		"gunshi": "catalog:runtime",
		"path-type": "catalog:runtime",
		"picocolors": "catalog:runtime",
		"tinyglobby": "catalog:runtime",
		"tsdown": "catalog:build",
		"unplugin-macros": "catalog:build",
		"unplugin-unused": "catalog:build",
		"valibot": "catalog:runtime",
		"vitest": "catalog:testing"
	},
	"keywords": [
		"amp",
		"llm",
		"water",
		"water-tracker",
		"water-footprint",
		"token",
		"token-usage",
		"usage",
		"sustainability",
		"ai",
		"ai-tools",
		"cli",
		"devtools",
		"carbon",
		"environment",
		"anthropic",
		"claude"
	]
}
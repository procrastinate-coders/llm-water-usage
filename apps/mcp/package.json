{
  "name": "llm-water-mcp",
  "type": "module",
  "version": "18.0.13",
  "description": "MCP server for llm-water-tracker — query LLM token usage and water consumption from Claude Desktop and other MCP clients.",
  "author": "Udit Garg",
  "license": "MIT",
  "homepage": "https://github.com/procrastinate-coders/llm-water-usage#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/procrastinate-coders/llm-water-usage.git",
    "directory": "apps/mcp"
  },
  "bugs": {
    "url": "https://github.com/procrastinate-coders/llm-water-usage/issues"
  },
  "exports": {
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "llm-water-mcp": "./src/index.ts"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "bin": {
      "llm-water-mcp": "./dist/index.js"
    },
    "exports": {
      ".": "./dist/index.js",
      "./package.json": "./package.json"
    }
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "dependencies": {
    "@hono/mcp": "catalog:runtime",
    "@hono/node-server": "catalog:runtime",
    "@modelcontextprotocol/sdk": "catalog:runtime",
    "llm-water-codex": "workspace:*",
    "llm-water-tracker": "workspace:*",
    "gunshi": "catalog:runtime",
    "hono": "catalog:runtime",
    "nano-spawn": "catalog:runtime",
    "zod": "catalog:runtime"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-desktop",
    "llm",
    "water",
    "water-tracker",
    "water-footprint",
    "token",
    "token-usage",
    "usage",
    "sustainability",
    "ai",
    "ai-tools",
    "devtools",
    "carbon",
    "environment",
    "anthropic",
    "claude"
  ]
}